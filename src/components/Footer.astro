---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#02172f] text-slate-300 py-16 border-t border-[#042446]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <!-- Coluna 1: Sobre -->
      <div>
        <h3 class="text-orange-500 font-bold text-xl mb-6 tracking-wide">Sobre</h3>
        <ul class="space-y-4">
          <li><a href="/" class="hover:text-white transition-colors">início</a></li>
          <li><a href="/sobrenos" class="hover:text-white transition-colors">Sobre nós</a></li>
          <li><a href="/politica-de-privacidade" class="hover:text-white transition-colors">Política de privacidade</a></li>
          <li><a href="https://wa.me/5547996372129" class="hover:text-white transition-colors">Contato</a></li>
        </ul>
      </div>

      <!-- Coluna 2: Contato -->
      <div>
        <h3 class="text-orange-500 font-bold text-xl mb-6 tracking-wide">Contato</h3>
        <ul class="space-y-4">
          <li class="flex items-start">
            <svg class="w-5 h-5 text-orange-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>
            <span>Centro, Bal. Piçarras, SC.</span>
          </li>
          <li class="flex items-start">
            <svg class="w-5 h-5 text-orange-500 mr-3 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path><path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path></svg>
            <a href="mailto:contato@anfitriaopicarras.com" class="hover:text-white transition-colors">contato@anfitriaopicarras.com</a>
          </li>
        </ul>
      </div>

      <!-- Coluna 3: Anfitrião Profissional -->
      <div>
        <h3 class="text-orange-500 font-bold text-xl mb-6 tracking-wide">Anfitrião Profissional</h3>
        <p class="mb-6 leading-relaxed">Todos os serviços para a sua locação de temporada.</p>
        <a 
          href="https://wa.me/5547996372129" 
          target="_blank"
          class="inline-flex items-center gap-2 bg-[#f68b24] hover:bg-orange-600 text-white px-8 py-3 rounded-full font-bold text-sm tracking-widest transition-transform hover:scale-105"
        >
          SAIBA MAIS
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
        </a>
      </div>

    </div>

    <!-- Linha Divisória e Copyright -->
    <div class="pt-8 mt-4 border-t border-[#123150] flex flex-col md:flex-row justify-between items-center gap-6">
      <!-- Logo Minimalista Customizada -->
      <div class="flex items-center gap-3">
        <svg class="w-10 h-10 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
          <path d="M3 21h18"></path>
          <path d="M9 21v-4a3 3 0 0 1 6 0v4"></path>
        </svg>
        <div class="leading-tight">
          <span class="block text-white font-bold text-lg">Anfitrião</span>
          <span class="block text-white font-bold text-lg" style="margin-top:-2px;">Piçarras</span>
        </div>
      </div>
      
      <p class="text-sm text-slate-400 text-center md:text-right">
        Copyright © {currentYear} Anfitrião Piçarras.<br class="md:hidden" /> Todos Os Direitos Reservados.
      </p>
    </div>
  </div>
</footer>
