---
const menuItems = [
  { name: 'Sobre nós', href: '/sobrenos' },
  { name: 'Serviços', href: '/servicos' },
  { name: 'Anuncie seu imóvel', href: '/Anuncieseuimovel' },
  { name: 'Blog', href: '/' }
];
---

<header class="bg-white shadow-md sticky top-0 z-50 w-full" id="main-header">
  <nav class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="flex items-center justify-between h-24">
      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="hover:opacity-80 transition-opacity flex items-center gap-2 text-[#02172f]">
          <svg class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
            <circle cx="12" cy="10" r="3"></circle>
            <path d="M3 21h18"></path>
            <path d="M9 21v-4a3 3 0 0 1 6 0v4"></path>
          </svg>
          <div class="leading-tight hidden sm:block">
            <span class="block font-black text-xl tracking-tighter">ANFITRIÃO</span>
            <span class="block font-black text-xl tracking-tighter text-orange-500" style="margin-top:-6px;">PIÇARRAS</span>
          </div>
        </a>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden md:flex items-center space-x-10">
        {menuItems.map(item => (
          <a 
            href={item.href} 
            class="text-sm font-bold text-slate-800 uppercase tracking-widest hover:text-orange-500 transition-colors"
          >
            {item.name}
          </a>
        ))}
        
        <!-- CTA Button -->
        <a 
          href="https://wa.me/5547996372129?text=Gostaria+de+receber+mais+informações+sobre+Anfitrião+Piçarras." 
          target="_blank"
          class="inline-flex items-center gap-2 bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-full font-bold text-sm uppercase tracking-tighter transition-all hover:scale-105 active:scale-95 shadow-lg shadow-orange-500/30"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
          Contato
        </a>
      </div>

      <!-- Mobile Menu Button (Hamburger) -->
      <div class="md:hidden flex items-center">
        <button type="button" class="text-slate-800 hover:text-orange-500 p-2" id="mobile-menu-button">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu Content (Hidden by default) -->
  <div class="hidden md:hidden bg-white border-t border-slate-100" id="mobile-menu">
    <div class="px-4 pt-2 pb-6 space-y-2 shadow-inner">
      {menuItems.map(item => (
        <a 
          href={item.href} 
          class="block px-3 py-4 text-base font-bold text-slate-800 hover:bg-slate-50 hover:text-orange-500 rounded-xl transition-colors"
        >
          {item.name}
        </a>
      ))}
      <a 
        href="https://wa.me/5547996372129" 
        class="block w-full text-center bg-orange-500 text-white px-6 py-4 rounded-xl font-bold uppercase tracking-widest mt-4"
      >
        WhatsApp
      </a>
    </div>
  </div>
</header>

<script>
  // Script rápido para o menu mobile
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
