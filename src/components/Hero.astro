---
---
<section class="relative bg-white pt-[100px] pb-[80px] lg:pt-[150px] lg:pb-[100px]">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="flex flex-wrap items-center -mx-4">
      <div class="w-full lg:w-5/12 px-4">
        <div class="hero-content">
          <h1 class="mb-5 text-4xl font-extrabold leading-tight text-slate-900 sm:text-5xl sm:leading-tight lg:text-5xl lg:leading-tight">
            Tranquilidade para você. Rentabilidade para o seu imóvel.
          </h1>
          <p class="mb-8 max-w-[480px] text-base text-slate-600 sm:text-lg">
            Gestão completa e profissional de propriedades para locação por temporada em Balneário Piçarras e região - SC.
          </p>
          <ul class="flex flex-wrap items-center gap-4">
            <li>
              <a href="#como-funciona" class="inline-flex items-center justify-center rounded-lg bg-blue-600 py-4 px-6 text-base font-medium text-white transition duration-300 hover:bg-blue-700 shadow-lg hover:shadow-blue-500/30">
                Descubra Como Funciona
              </a>
            </li>
            <li>
              <a href="#contato" class="inline-flex items-center justify-center rounded-lg bg-transparent py-4 px-6 text-base font-medium text-slate-900 border border-slate-300 transition duration-300 hover:bg-slate-50 hover:border-slate-400">
                Falar com Consultor
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="hidden px-4 lg:block lg:w-1/12"></div>
      <div class="w-full px-4 lg:w-6/12 mt-12 lg:mt-0">
        <div class="lg:ml-auto lg:text-right relative">
          <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?ixlib=rb-4.0.3&auto=format&fit=crop&w=1170&q=80" alt="Imóvel em Piçarras" class="max-w-full rounded-2xl shadow-2xl relative z-10" />
          <div class="absolute -bottom-6 -left-6 z-0 w-64 h-64 bg-blue-100 rounded-full mix-blend-multiply filter blur-2xl opacity-70 animate-blob"></div>
          <div class="absolute -top-6 -right-6 z-0 w-64 h-64 bg-yellow-100 rounded-full mix-blend-multiply filter blur-2xl opacity-70 animate-blob animation-delay-2000"></div>
        </div>
      </div>
    </div>
  </div>
</section>
