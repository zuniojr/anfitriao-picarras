---
const steps = [
  {
    number: "01",
    title: "Avaliação do Imóvel",
    description: "Estudamos o potencial de rentabilidade do seu imóvel de forma realista."
  },
  {
    number: "02",
    title: "Preparação e Fotos",
    description: "Sessões de fotos de alta qualidade e preparo visual impecável do ambiente."
  },
  {
    number: "03",
    title: "Publicação Otimizada",
    description: "Anúncios desenhados com SEO para atrair as melhores reservas."
  },
  {
    number: "04",
    title: "Hospedagem Lucrativa",
    description: "A partir daqui, nosso time cuida 100% de reservas, limpeza e repasses."
  }
];
---

<section id="como-funciona" class="py-16 bg-white lg:py-24">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <span class="text-blue-600 font-bold tracking-wider uppercase text-sm">Passo a Passo</span>
      <h2 class="mt-2 text-3xl font-extrabold text-slate-900 sm:text-4xl">O caminho para o sucesso</h2>
      <p class="mt-4 text-lg text-slate-600">Simplicidade e transparência em cada etapa da nossa rotina de gestão.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map(step => (
        <div class="relative flex flex-col items-center text-center group">
          <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center text-2xl font-bold mb-6 shadow-sm group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300">
            {step.number}
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{step.title}</h3>
          <p class="text-slate-600">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
