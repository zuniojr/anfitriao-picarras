---
const testimonials = [
  {
    name: "Carlos E.",
    role: "Proprietário",
    content: "Profissionalismo fantástico. Antes o Airbnb era meu 2º trabalho, hoje é apenas renda passiva caindo.",
    avatar: "https://i.pravatar.cc/150?img=11"
  },
  {
    name: "Mariana S.",
    role: "Investidora",
    content: "Avaliações só em 5 estrelas! Eles mantêm meu apê limpo e com manutenção sempre em dia.",
    avatar: "https://i.pravatar.cc/150?img=5"
  }
];
---

<section id="depoimentos" class="py-16 bg-slate-900 text-white lg:py-24">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-extrabold sm:text-4xl">Aprovação de quem importa</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      {testimonials.map(testimonial => (
        <div class="bg-slate-800 rounded-2xl p-8 border border-slate-700 hover:border-blue-500 transition-colors">
          <div class="flex items-center mb-6">
            <img src={testimonial.avatar} alt={testimonial.name} class="w-14 h-14 rounded-full border-2 border-slate-600 mr-4" />
            <div>
              <h4 class="font-bold text-lg">{testimonial.name}</h4>
              <p class="text-slate-400 text-sm">{testimonial.role}</p>
            </div>
          </div>
          <p class="text-slate-300 italic">"{testimonial.content}"</p>
        </div>
      ))}
    </div>
  </div>
</section>
