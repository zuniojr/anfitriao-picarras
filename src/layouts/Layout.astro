---
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Anfitrião Piçarras - Gestão Profissional de Imóveis para Temporada no Litoral de Santa Catarina" } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-white text-slate-900 font-sans antialiased selection:bg-orange-600 selection:text-white">
		<Header />
		<slot />
	</body>
</html>

<style is:global>
	@tailwind base;
	@tailwind components;
	@tailwind utilities;

	/* Forçar fontes e estilos base caso o Tailwind falhe no build inicial */
	body {
		margin: 0;
		padding: 0;
		overflow-x: hidden;
	}
</style>
